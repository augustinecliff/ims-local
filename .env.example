# API
VITE_API_BASE_URL=http://localhost:8080/api

# Auth — set to true until Keycloak dev env is available
VITE_MOCK_AUTH=true

# API mocking — set to true until backend endpoints are available
VITE_MOCK_API=true

# Feature flags — hide incomplete modules in staging
VITE_FEATURE_RISK=false
VITE_FEATURE_ENGAGEMENT=false

# Living preview — speed multiplier (1 = ~80s loop, 2 = ~40s loop)
# VITE_PREVIEW_SPEED=1

# Keycloak (wire up in Phase 1)
# VITE_KEYCLOAK_URL=
# VITE_KEYCLOAK_REALM=
# VITE_KEYCLOAK_CLIENT_ID=
